APP_NAME=IMS Backend
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://ims:ims@postgres:5432/ims
MONGO_URL=mongodb://mongo:27017
MONGO_DB=ims
QUEUE_STREAM=ims:signals
QUEUE_GROUP=ims-workers
QUEUE_CONSUMER=worker-1
RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_WINDOW_SECONDS=60
DEBOUNCE_TTL_SECONDS=10
METRICS_INTERVAL_SECONDS=5
